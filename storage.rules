rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Audio files organized by userId
    match /audio/{userId}/{allPaths=**} {
      // Allow read if user is authenticated and accessing their own files
      allow read: if isAuthenticated() && request.auth.uid == userId;
      
      // Allow write (upload/update/delete) if user is authenticated and accessing their own files
      allow write: if isAuthenticated() 
                   && request.auth.uid == userId
                   && request.resource.size < 100 * 1024 * 1024  // Max 100MB per file
                   && request.resource.contentType.matches('audio/.*');  // Only audio files
    }
    
    // Deny all other access by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
